<style>
    .btn-search{
      background-color: #fe424d;
      color: white;
      border-radius:25px;
      padding: 0 1rem 0 1rem;
    }
    .btn-search:hover{
      background-color: #fe424d;
      color: white;
    }
    .btn-search i {
      display: inline;
      margin-right: 0.5rem;
    }
    .search-input {
      border-radius: 25px;
      border: 1px solid rgb(161, 154, 154);
      padding: 0.5rem 1rem;
      width: 300px;
    }
</style>
<nav class="navbar navbar-expand-md bg-body-light border-bottom sticky-top">
  <div class="container-fluid">
    <a class="navbar-brand navbar-nav" href="/listings">
      <i class="fa-solid fa-compass"></i>StaySphere
    </a>
    <button
      class="navbar-toggler"
      type="button"
      data-bs-toggle="collapse"
      data-bs-target="#navbarNavAltMarkup"
    >
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarNavAltMarkup">
      <div class="navbar-nav">
        <a class="nav-link" href="/listings">Explore</a>
        <a class="nav-link" href="/listings/new">List Your Property</a>
      </div>

      <!-- search bar -->
      <div class="navbar-nav ms-auto">
        <form class="d-flex" role="search">
          <input class="form-control me-2 search-input" type="search" placeholder="Search your Destination" aria-label="Search"/>
          <button class="btn btn-search" type="submit"><i class="fa-solid fa-magnifying-glass"></i>Search</button>
        </form>
      </div>

      <div class="navbar-nav ms-auto">
        <!-- ms-auto pushes the links to the right -->
         <% if(!currentUser) { %>
        <a class="nav-link" aria-current="page" href="/signup"><b>Sign Up</b></a>
        <a class="nav-link" href="/login"><b>Login</b></a>
         <% } else { %>
        <a class="nav-link" href="/logout"><b>Logout</b></a>
         <% } %>
      </div>
    </div>
  </div>
</nav>
