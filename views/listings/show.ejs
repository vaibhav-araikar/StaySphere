<% layout("layouts/boilerplate") %>
<div class="row mt-4">
  <div class="col-8 offset-3">
    <h3><%= listing.title %></h3>
  </div>

  <div class="card col-6 offset-3 show-card listing-card">
    <img
      src="<%= listing.image.url %>"
      class="card-img-top show-img"
      alt="listing image"
    />
    <div class="card-body">
      <%= listing.description %> <br />
      Price: &#8377;<%= listing.price.toLocaleString("en-IN") %> per night
      <br />
      Location: <%= listing.location %> <br />
      Country: <%= listing.country %>
    </div>
  </div>

  <br />
</div>

<!-- buttons -->
<div class="btns">
  <a
    href="/listings/<%=listing._id%>/edit"
    class="btn btn-dark col-1 offset-3 update-listing-btn"
    >Edit Listing</a
  >

  <form method="POST" action="/listings/<%=listing._id%>?_method=DELETE">
    <button type="submit" class="btn btn-dark offset-5">Delete Listing</button>
  </form>

  <form action="/listings" method="GET">
    <button type="submit" class="btn btn-dark offset-5">
      Back to Listings
    </button>
  </form>
  </div>
  <hr>

  <!-- Review Form -->
  <div class="col-8 offset-3 mb-3">
    <h4>Leave a Review</h4>
    <form action="/listings/<%=listing._id%>/reviews" method="POST" novalidate class="needs-validation">
      <div class="mb-3">
        <label for="rating" class="form-label" >Rating</label>
        <input type="range" min="1" max="5" id="rating" name="review[rating]" class="form-range"/>
      </div>
      <div class="mb-3">
        <label for="comment" class="form-label">Comments</label>
        <textarea
          id="comment"
          name="review[comment]"
          class="form-control"
          rows="5"
          cols="10"
          class="form-control"
          required
        ></textarea>
        <div class="invalid-feedback">Please enter your comments.</div>
      </div>
      <button type="submit" class="btn btn-dark mt-2">Submit Review</button>
    </form>

    <hr>

    <h4>Customer Reviews</h4>
    <div class="row">
      <% for(review of listing.reviews) { %>
        <div class="card mb-3 col-5 ms-3">
          <div class="card-body">
            <h5 class="card-title">Vaibhav Araikar</h5>
            <p class="card-text"><%= review.comment %></p>
            <p class="card-text">Rating: <%= review.rating %> / 5</p>
            <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" class="mb-3" method="POST">
              <button type="submit" class="btn btn-dark">Delete</button>
            </form>
          </div>
        </div>
      <% } %> 
    </div>
  </div>
</div>
